{
  "name": "clibase",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./dist-electron/main/main.cjs",
  "bin": {
    "batcli": "./bin/batcli.js"
  },
  "scripts": {
    "batcli": "node ./bin/batcli.js",
    "dev": "node ./bin/batcli.js dev",
    "app:dev": "concurrently -k -s first \"npm:dev:renderer\" \"npm:dev:electron:compile\" \"npm:dev:electron:run\"",
    "dev:renderer": "vite",
    "dev:electron:compile": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron:run": "node ./scripts/run-electron-dev.cjs",
    "build": "node ./bin/batcli.js build",
    "app:build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "node ./bin/batcli.js preview",
    "app:preview": "vite preview",
    "typecheck": "node ./bin/batcli.js typecheck",
    "app:typecheck": "npm run typecheck:renderer && npm run typecheck:electron",
    "typecheck:renderer": "tsc --noEmit",
    "typecheck:electron": "tsc --noEmit -p tsconfig.electron.json",
    "verify": "node ./bin/batcli.js verify",
    "docs:validate": "node ./bin/batcli.js docs validate",
    "workflow:status": "node ./bin/batcli.js workflow status",
    "uia:record-terminal": "tsx scripts/uia-terminal-record.ts",
    "uia:pipeline-e2e": "node scripts/uia-terminal-e2e.mjs",
    "uia:verify-test-host-exe": "node scripts/verify-uia-recording-test-host-exe.mjs",
    "uia:install-runtime": "node scripts/ensure-dotnet-aspnetcore-runtime.mjs",
    "vm-gennx:resolve-config": "node scripts/vm-gennx-resolve-config.mjs"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mantine/core": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@microsoft/signalr": "^10.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "0.487.0",
    "node-pty": "^1.1.0",
    "react": "18.3.1",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-dom": "18.3.1",
    "react-router-dom": "7.13.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "4.7.0",
    "concurrently": "9.2.1",
    "electron": "41.0.3",
    "tailwindcss": "4.1.12",
    "tsx": "^4.21.0",
    "tw-animate-css": "1.3.8",
    "typescript": "^5.9.3",
    "vite": "6.3.5",
    "wait-on": "9.0.4"
  }
}
