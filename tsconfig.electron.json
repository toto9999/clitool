{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "rootDir": "electron",
    "outDir": "dist-electron",
    "types": ["node"],
    "sourceMap": true
  },
  "include": ["electron/**/*.ts", "electron/**/*.cts"]
}
